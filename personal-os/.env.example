# ===== Personal OS Environment Variables =====
# Copy this file to .env.local and fill in your values.

# --- AI Features (Google Gemini) ---
# Get your API key at: https://aistudio.google.com/app/apikey
# You can add multiple keys for round-robin rotation (optional).
# At a minimum, GEMINI_API_KEY_1 is required for AI features.
GEMINI_API_KEY_1=your_gemini_api_key_here
# GEMINI_API_KEY_2=optional_second_key
# GEMINI_API_KEY_3=optional_third_key

# --- Cloud Database (Phase 4 — not yet active) ---
# PostgreSQL connection string for Supabase or local Docker.
# Not required for local-only usage.
# DATABASE_URL=postgresql://user:password@host:5432/personal_os
